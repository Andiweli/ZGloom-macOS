prefix=/Users/andreas.stuermer/Documents/Xcode Projekte/ZGloom/Frameworks/Universal
exec_prefix=${prefix}
libdir=${prefix}
includedir=/opt/homebrew/include

Name: sdl2
Description: SDL2 universal override for ZGloom
Version: 2
Libs: -L${libdir} -lSDL2
Cflags: -I${includedir} -I${includedir}/SDL2 -D_THREAD_SAFE
