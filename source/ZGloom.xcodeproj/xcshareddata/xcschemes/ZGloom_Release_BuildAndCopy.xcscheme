<?xml version="1.0" encoding="UTF-8"?>
<Scheme
   LastUpgradeVersion = "2610"
   version = "1.7">
   <BuildAction
      parallelizeBuildables = "YES"
      buildImplicitDependencies = "YES"
      buildArchitectures = "Automatic">
      <PostActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Copy Release binary into ../ZGloom.app"
               scriptText = "set -e&#10;export ZGLOOM_APP_BUNDLE=&quot;$SRCROOT/../ZGloom.app&quot;&#10;echo &quot;[ZGloom.app copy] Scheme post-build copy running after Release build.&quot;&#10;echo &quot;[ZGloom.app copy] BUILT_PRODUCTS_DIR=$BUILT_PRODUCTS_DIR&quot;&#10;echo &quot;[ZGloom.app copy] EXECUTABLE_NAME=$EXECUTABLE_NAME&quot;&#10;bash &quot;$SRCROOT/scripts/package_macos_app_bundle.sh&quot; &quot;$BUILT_PRODUCTS_DIR/$EXECUTABLE_NAME&quot; &quot;$ZGLOOM_APP_BUNDLE&quot;">
               <EnvironmentBuildable>
                  <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "8D044114C40C818466978EAA"
               BuildableName = "zgloom"
               BlueprintName = "ZGloom"
               ReferencedContainer = "container:ZGloom.xcodeproj">
            </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
      <BuildActionEntries>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "YES"
            buildForProfiling = "YES"
            buildForArchiving = "YES"
            buildForAnalyzing = "YES">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "8D044114C40C818466978EAA"
               BuildableName = "zgloom"
               BlueprintName = "ZGloom"
               ReferencedContainer = "container:ZGloom.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
      </BuildActionEntries>
   </BuildAction>
   <TestAction
      buildConfiguration = "Release"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "YES">
      <Testables>
      </Testables>
   </TestAction>
   <LaunchAction
      buildConfiguration = "Release"
